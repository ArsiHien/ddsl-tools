{
  "name": "ddsl-tools",
  "displayName": "ddsl-tools",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ddsl"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ddsl",
        "aliases": [
          "DDSL",
          "ddsl"
        ],
        "extensions": [
          ".ddsl"
        ]
      }
    ],
    "commands": [
      {
        "command": "ddsl.compileAction",
        "title": "Compile DDSL",
        "category": "DDSL"
      },
      {
        "command": "ddsl.generateAI",
        "title": "Generate DDSL from Natural Language",
        "category": "DDSL"
      },
      {
        "command": "ddsl.generateDiagramAction",
        "title": "Generate Diagram",
        "category": "DDSL"
      },
      {
        "command": "ddsl.generateComponentDiagramAction",
        "title": "Generate Component Diagram",
        "category": "DDSL"
      },
      {
        "command": "ddsl.generateEventFlowDiagramAction",
        "title": "Generate Event Flow Diagram",
        "category": "DDSL"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ddsl.compileAction",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@1"
        },
        {
          "command": "ddsl.generateAI",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@2"
        },
        {
          "command": "ddsl.generateComponentDiagramAction",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@3"
        },
        {
          "command": "ddsl.generateEventFlowDiagramAction",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "ddsl.compileAction",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@1"
        },
        {
          "command": "ddsl.generateAI",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@2"
        },
        {
          "command": "ddsl.generateComponentDiagramAction",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@3"
        },
        {
          "command": "ddsl.generateEventFlowDiagramAction",
          "when": "resourceExtname == .ddsl",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "ddsl.compileAction"
        },
        {
          "command": "ddsl.generateAI"
        },
        {
          "command": "ddsl.generateDiagramAction"
        },
        {
          "command": "ddsl.generateComponentDiagramAction",
          "when": "resourceLangId == ddsl"
        },
        {
          "command": "ddsl.generateEventFlowDiagramAction",
          "when": "resourceLangId == ddsl"
        }
      ]
    },
    "configuration": {
      "title": "DDSL",
      "properties": {
        "ddsl.compile.outputDir": {
          "type": "string",
          "default": ".ddsl-output",
          "description": "Folder name for compile artifacts and AI diff snapshots."
        },
        "ddsl.ai.apiUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL of the AI service (without /api/translate)."
        },
        "ddsl.ai.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for AI API calls."
        },
        "ddsl.ai.maxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "description": "Number of retries when AI API calls fail or time out."
        }
      }
    },
    "configurationDefaults": {
      "[ddsl]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "semanticTokenScopes": [
      {
        "language": "ddsl",
        "scopes": {
          "namespace": [
            "entity.name.namespace"
          ],
          "type": [
            "entity.name.type"
          ],
          "class": [
            "entity.name.class"
          ],
          "enum": [
            "entity.name.enum"
          ],
          "interface": [
            "entity.name.interface"
          ],
          "struct": [
            "entity.name.struct"
          ],
          "typeParameter": [
            "entity.name.type.parameter"
          ],
          "parameter": [
            "variable.parameter"
          ],
          "variable": [
            "variable.other.readwrite"
          ],
          "property": [
            "variable.other.property"
          ],
          "enumMember": [
            "variable.other.enummember"
          ],
          "event": [
            "support.type.event-name"
          ],
          "function": [
            "entity.name.function"
          ],
          "method": [
            "entity.name.function.member"
          ],
          "macro": [
            "entity.name.function.preprocessor"
          ],
          "keyword": [
            "keyword"
          ],
          "modifier": [
            "storage.modifier"
          ],
          "comment": [
            "comment"
          ],
          "string": [
            "string"
          ],
          "number": [
            "constant.numeric"
          ],
          "regexp": [
            "string.regexp"
          ],
          "operator": [
            "keyword.operator"
          ],
          "decorator": [
            "entity.name.function.decorator"
          ],
          "parameter.readonly": [
            "variable.parameter.readonly"
          ],
          "property.readonly": [
            "variable.other.property.readonly"
          ],
          "variable.readonly": [
            "variable.other.constant"
          ],
          "*.declaration": [
            "entity.name"
          ],
          "*.documentation": [
            "comment.block.documentation"
          ],
          "*.defaultLibrary": [
            "support"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "vscode-languageclient": "^9.0.1"
  }
}
